{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "chatbot-mesh values",
  "type": "object",
  "required": ["image", "ragUnits"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": {"type": "string"},
        "tag": {"type": "string"},
        "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]}
      }
    },
    "ragUnits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "collection", "embeddingModel"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"},
          "collection": {"type": "string", "minLength": 1},
          "embeddingModel": {"type": "string", "minLength": 1},
          "replicas": {"type": "integer", "minimum": 0}
        }
      }
    },
    "llm": {
      "type": "object",
      "properties": {
        "inCluster": {"type": "boolean"},
        "externalURL": {"type": "string"},
        "port": {"type": "integer"}
      }
    },
    "dolt": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
    "collector": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
    "jaeger": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "host": {"type": "string"}
      }
    }
  }
}
