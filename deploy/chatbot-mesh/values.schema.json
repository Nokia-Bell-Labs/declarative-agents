{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "chatbot-mesh values",
  "type": "object",
  "required": ["image", "ragUnits"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": {"type": "string"},
        "tag": {"type": "string"},
        "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]}
      }
    },
    "ragUnits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "collection", "embeddingModel"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"},
          "collection": {"type": "string", "minLength": 1},
          "embeddingModel": {"type": "string", "minLength": 1},
          "replicas": {"type": "integer", "minimum": 0}
        }
      }
    },
    "llm": {
      "type": "object",
      "properties": {
        "externalURL": {"type": "string"},
        "port": {"type": "integer"}
      }
    },
    "ollama": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "image": {"type": "object", "properties": {"repository": {"type": "string"}, "tag": {"type": "string"}}},
        "models": {
          "type": "object",
          "required": ["embedding", "chat", "router"],
          "properties": {
            "embedding": {"type": "string"},
            "chat": {"type": "array", "items": {"type": "string"}},
            "router": {"type": "string"}
          }
        },
        "persistence": {"type": "object", "properties": {"size": {"type": "string"}, "storageClass": {"type": "string"}}},
        "gpu": {"type": "object", "properties": {"count": {"type": "integer"}}},
        "nodeSelector": {"type": "object"},
        "tolerations": {"type": "array"},
        "topology": {"type": "string", "enum": ["single", "per-model"]}
      }
    },
    "dolt": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
    "collector": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
    "jaeger": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "host": {"type": "string"}
      }
    }
  }
}
